3\">\r\n        <h5>Section</h5>\r\n        <ul class=\"nav flex-column\">\r\n          <li class=\"nav-item mb-2\"><a href=\"#\" class=\"nav-link p-0 text-body-secondary\">Home</a></li>\r\n          <li class=\"nav-item mb-2\"><a href=\"#\" class=\"nav-link p-0 text-body-secondary\">Features</a></li>\r\n          <li class=\"nav-item mb-2\"><a href=\"#\" class=\"nav-link p-0 text-body-secondary\">Pricing</a></li>\r\n          <li class=\"nav-item mb-2\"><a href=\"#\" class=\"nav-link p-0 text-body-secondary\">FAQs</a></li>\r\n          <li class=\"nav-item mb-2\"><a href=\"#\" class=\"nav-link p-0 text-body-secondary\">About</a></li>\r\n        </ul>\r\n      </div>\r\n\r\n      <div class=\"col-6 col-md-2 mb-3\">\r\n        <h5>Section</h5>\r\n        <ul class=\"nav flex-column\">\r\n          <li class=\"nav-item mb-2\"><a href=\"#\" class=\"nav-link p-0 text-body-secondary\">Home</a></li>\r\n          <li class=\"nav-item mb-2\"><a href=\"#\" class=\"nav-link p-0 text-body-secondary\">Features</a></li>\r\n          <li class=\"nav-item mb-2\"><a href=\"#\" class=\"nav-link p-0 text-body-secondary\">Pricing</a></li>\r\n          <li class=\"nav-item mb-2\"><a href=\"#\" class=\"nav-link p-0 text-body-secondary\">FAQs</a></li>\r\n          <li class=\"nav-item mb-2\"><a href=\"#\" class=\"nav-link p-0 text-body-secondary\">About</a></li>\r\n        </ul>\r\n      </div>\r\n\r\n      <div class=\"col-6 col-md-2 mb-3\">\r\n        <h5>Section</h5>\r\n        <ul class=\"nav flex-column\">\r\n          <li class=\"nav-item mb-2\"><a href=\"#\" class=\"nav-link p-0 text-body-secondary\">Home</a></li>\r\n          <li class=\"nav-item mb-2\"><a href=\"#\" class=\"nav-link p-0 text-body-secondary\">Features</a></li>\r\n          <li class=\"nav-item mb-2\"><a href=\"#\" class=\"nav-link p-0 text-body-secondary\">Pricing</a></li>\r\n          <li class=\"nav-item mb-2\"><a href=\"#\" class=\"nav-link p-0 text-body-secondary\">FAQs</a></li>\r\n          <li class=\"nav-item mb-2\"><a href=\"#\" class=\"nav-link p-0 text-body-secondary\">About</a></li>\r\n        </ul>\r\n      </div>\r\n\r\n      <div class=\"col-md-5 offset-md-1 mb-3\">\r\n        <form>\r\n          <h5>Subscribe to our newsletter</h5>\r\n          <p>Monthly digest of what's new and exciting from us.</p>\r\n          <div class=\"d-flex flex-column flex-sm-row w-100 gap-2\">\r\n            <label for=\"newsletter1\" class=\"visually-hidden\">Email address</label>\r\n            <input id=\"newsletter1\" type=\"text\" class=\"form-control\" placeholder=\"Email address\"/>\r\n            <button class=\"btn btn-primary\" type=\"button\">Subscribe</button>\r\n          </div>\r\n        </form>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"d-flex flex-column flex-sm-row justify-content-between py-4 my-4 border-top\">\r\n      <p>© 2024 Company, Inc. All rights reserved.</p>\r\n      <ul class=\"list-unstyled d-flex\">\r\n        {/* <li class=\"ms-3\"><a class=\"link-body-emphasis\" href=\"#\"><svg class=\"bi\" width=\"24\" height=\"24\"><use xlink:href=\"#twitter\"></use></svg></a></li>\r\n        <li class=\"ms-3\"><a class=\"link-body-emphasis\" href=\"#\"><svg class=\"bi\" width=\"24\" height=\"24\"><use xlink:href=\"#instagram\"></use></svg></a></li>\r\n        <li class=\"ms-3\"><a class=\"link-body-emphasis\" href=\"#\"><svg class=\"bi\" width=\"24\" height=\"24\"><use xlink:href=\"#facebook\"></use></svg></a></li> */}\r\n      </ul>\r\n    </div>\r\n  </footer>\r\n</div>\r\n  //   <div class=\"container fluid\">\r\n  //   <footer class=\"d-flex flex-wrap justify-content-between align-items-center py-3 my-4 border-top\">\r\n  //     <div class=\"col-md-4 d-flex align-items-center\">\r\n  //       <a href=\"/\" class=\"mb-3 me-2 mb-md-0 text-muted text-decoration-none lh-1\">\r\n  //       </a>\r\n  //       <span class=\"text-muted\">© 2021 Company, Inc</span>\r\n  //     </div>\r\n  \r\n  //     <ul class=\"nav col-md-4 justify-content-end list-unstyled d-flex\">\r\n  //     </ul>\r\n  //   </footer>\r\n  // </div>\r\n  )\r\n}\r\n\r\nexport default Footer","D:\\quizz-mern\\frontend\\src\\pages\\register\\Register.jsx",["146"],[],"import React from 'react'\r\nimport { useDispatch,useSelector } from 'react-redux'\r\nimport { useState,useEffect } from 'react'\r\nimport { registerUser } from '../../actions/userActions'\r\nimport  pic from \"../../img/pic.webp\"\r\n\r\nconst Register = () => {\r\n  const dispatch=useDispatch()\r\n  const { register } = useSelector(\r\n    (state) => state.appInfo\r\n  );\r\n  const [formData,setFormData]=useState({name:\"\",email:\"\",password:\"\"})\r\n  const handleSubmit=(event)=>{\r\n    event.preventDefault();\r\n    dispatch(registerUser(formData)) \r\n}\r\n  function handleChange(event){\r\n    setFormData({...formData,[event.target.name]:event.target.value})\r\n  }\r\n  return (\r\n    <div class=\"text-center my-4\">\r\n    \r\n<main class=\"form-signin w-50 m-auto\">\r\n  <form>\r\n    <img class=\"mb-4\" src={pic} alt=\"\" width=\"72\" height=\"57\"/>\r\n    <h1 class=\"h3 mb-3 fw-normal\">Please Register</h1>\r\n\r\n    <div class=\"form-floating\">\r\n      <input type=\"name\" class=\"form-control my-2\" id=\"floatingInput\" placeholder=\"xyz\"\r\n      name=\"name\"\r\n      onChange={handleChange} />\r\n      <label for=\"floatingInput\">Name</label>\r\n    </div>\r\n    <div class=\"form-floating\">\r\n      <input type=\"email\" class=\"form-control my-2\" id=\"floatingInput\" placeholder=\"name@example.com\"\r\n      name=\"email\"\r\n      onChange={handleChange}\r\n      />\r\n      <label for=\"floatingInput\">Email address</label>\r\n    </div>\r\n    <div class=\"form-floating\">\r\n      <input type=\"password\" class=\"form-control my-2\" id=\"floatingPassword\" placeholder=\"Password\"\r\n      name=\"password\"\r\n      onChange={handleChange}\r\n      />\r\n      <label for=\"floatingPassword\">Password</label>\r\n    </div>\r\n\r\n    <div class=\"checkbox mb-3\">\r\n      <label>\r\n        <input type=\"checkbox\" value=\"remember-me\"/> Remember me\r\n      </label>\r\n    </div>\r\n    {register.success?<b className='text-success my-2'>Registered successfully you can log in now !!!</b>:<b className='text-danger my-2'>{register.message}</b>}\r\n    <button class=\"w-100 btn btn-lg btn-primary\" type=\"submit\" onClick={handleSubmit} >Sign in</button>\r\n    <p class=\"mt-5 mb-3 text-muted\">© 2017–2022</p>\r\n  </form>\r\n</main>\r\n\r\n\r\n    \r\n\r\n\r\n</div>\r\n  )\r\n}\r\n\r\nexport default Register\r\n","D:\\quizz-mern\\frontend\\src\\pages\\home\\Home.jsx",["147","148"],[],"import React from 'react'\r\nimport banner from '../../images/banner.webp'\r\nimport { Link } from 'react-router-dom'\r\n\r\nconst Home = () => {\r\n\r\n  return (\r\n     <>\r\n      <div class=\"position-relative overflow-hidden p-3 p-md-5 m-md-3 text-center bg-light\">\r\n    <div class=\"col-md-5 p-lg-5 mx-auto my-5\">\r\n      <h1 class=\"display-4 fw-normal\">Take a Quizz</h1>\r\n      <p class=\"lead fw-normal\">Lorem ipsum dolor sit, amet consectetur adipisicing elit. Beatae asperiores delectus blanditiis doloribus quos, aut dolorum fugit, tenetur et dolore veniam. Itaque commodi neque adipisci in unde optio ad dicta.</p>\r\n      <Link to=\"/register\"><a class=\"btn btn-outline-secondary\">Get started</a></Link>\r\n    </div>\r\n    <div class=\"product-device shadow-sm d-none d-md-block\"></div>\r\n    <div class=\"product-device product-device-2 shadow-sm d-none d-md-block\"></div>\r\n  </div>\r\n     </>\r\n        )\r\n}\r\n\r\nexport default Home","D:\\quizz-mern\\frontend\\src\\pages\\quizz\\Quizz.jsx",["149"],[],"import React from 'react'\r\nimport { useDispatch,useSelector } from 'react-redux'\r\nimport { useParams } from 'react-router-dom';\r\nimport { getQuizzD } from '../../actions/userActions';\r\nimport { useEffect } from 'react';\r\n\r\nconst Quizz = () => {\r\n  const {id}=useParams()\r\n  const dispatch=useDispatch()\r\n  useEffect(() => {\r\n    dispatch(getQuizzD(id))\r\n  }, [id])\r\n  const { quizzDetails } = useSelector(\r\n    (state) => state.appInfo\r\n  );\r\n  if (!quizzDetails.quizz) {\r\n    return null\r\n  } \r\n  \r\n  return (\r\n    <>\r\n    <div className=\"container my-4\">\r\n      <h3 className='text-center'>{ quizzDetails.quizz.quizname}</h3>\r\n      <p className='text-center'>{quizzDetails.quizz.quizdescription}</p>\r\n      {quizzDetails.quizz.questions.map(quest=><ol class=\"list-group list-group my-2\">\r\n  <li class=\"list-group-item d-flex justify-content-between align-items-start\">\r\n    <div class=\"ms-2 me-auto\">\r\n      <div class=\"fw-bold\">\r\n        Q. {quest.question}\r\n        </div> \r\n       A. {quest.options[0]} <br /> \r\n       B. {quest.options[1]} <br />\r\n       C. {quest.options[2]} <br />\r\n       D. {quest.options[3]} <br />\r\n       <b>correct ans : </b>{quest.answers.map(a=><b>,{a}</b>)}\r\n     </div>\r\n    <span class=\"badge bg-primary rounded-pill\">difficulty : {quest.difficulty}</span>\r\n  </li> \r\n</ol>)}\r\n    \r\n    </div>\r\n    </>\r\n  )\r\n}\r\n\r\nexport default Quizz","D:\\quizz-mern\\frontend\\src\\pages\\admin\\Admin.jsx",["150","151","152"],[],"import React from 'react'\r\nimport { Link } from 'react-router-dom'\r\nimport { useDispatch,useSelector } from 'react-redux'\r\nimport { getquizzes } from '../../actions/userActions'\r\nimport { useEffect } from 'react'\r\n\r\nconst Admin = () => {\r\n  const { quizzes,login } = useSelector(\r\n    (state) => state.appInfo\r\n  );\r\n  const dispatch=useDispatch()\r\n  useEffect(() => {\r\n    dispatch(getquizzes())\r\n  }, [])\r\n  return (\r\n    <>    \r\n    <h3 className='text-center my-4'>Quizzes</h3>\r\n    {quizzes.quizzes && quizzes.quizzes.map(quizz=><div className=\"container my-2\">\r\n    <ol class=\"list-group list-group\">\r\n  <li class=\"list-group-item d-flex justify-content-between align-items-start\">\r\n    <div class=\"ms-2 me-auto\">\r\n      <div class=\"fw-bold\">{quizz.quizname}</div>\r\n      {quizz.quizdescription}\r\n    </div>\r\n    {login.user.role=='admin'? <Link to={`/${quizz._id}`}><span class=\"badge bg-primary rounded-pill mx-2\">View</span>\r\n</Link>:<></>}\r\n    \r\n<Link to={`/playQuizz/${quizz._id}`}><span class=\"badge bg-success rounded-pill\">Play quizz</span>\r\n</Link>\r\n  </li>\r\n</ol>\r\n    </div>)}    \r\n    <div className=\"container\">\r\n      {login.user.role=='admin'? <Link to=\"/createQuizz\" ><button class=\"btn btn-lg btn-primary my-2 mx-2\" type=\"submit\">Create quizz</button>\r\n</Link>:<></>}\r\n    </div>\r\n    \r\n   </>\r\n  )\r\n}\r\n\r\nexport default Admin","D:\\quizz-mern\\frontend\\src\\pages\\createQuizz\\CreateQuizz.jsx",[],[],"D:\\quizz-mern\\frontend\\src\\pages\\playQuizz\\PlayQuizz.jsx",["153","154"],[],"import React from 'react'\r\nimport { useState,useEffect } from 'react'\r\nimport { useSelector,useDispatch } from 'react-redux'\r\nimport { getQuizzD } from '../../actions/userActions'\r\nimport { useParams } from 'react-router-dom'\r\nimport Result from '../result/Result'\r\n\r\nconst Instructions= ({isO}) =>{\r\n    return (\r\n        <>\r\n        <div class=\"modal modal-sheet position-static d-block  py-5\" tabindex=\"-1\" role=\"dialog\" id=\"modalSheet\">\r\n  <div class=\"modal-dialog\" role=\"document\">\r\n    <div class=\"modal-content rounded-4 shadow\">\r\n      <div class=\"modal-header border-bottom-0\">\r\n        <h1 class=\"modal-title fs-5\">Instructions</h1>\r\n      </div>\r\n      <div class=\"modal-body py-0\">\r\n        <p>Lorem, ipsum dolor sit amet consectetur adipisicing elit. Veritatis corrupti ducimus iure expedita voluptatibus eum sed rem? Veniam aperiam esse minus nobis facilis, minima porro. Adipisci ab accusantium doloremque. Nemo?.</p>\r\n      </div>\r\n      <div class=\"modal-footer flex-column border-top-0\">\r\n        <button type=\"button\" class=\"btn btn-lg btn-primary w-100 mx-0\" data-bs-dismiss=\"modal\" onClick={isO} >Close</button>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</div>\r\n        </>\r\n    )\r\n}\r\nconst PlayQuizz = () => {\r\n  const {id}=useParams()\r\n  const dispatch=useDispatch()\r\n  useEffect(() => {\r\n    dispatch(getQuizzD(id))\r\n  }, [id])\r\n  const [difficultyLevel,setDifficultyLevel] = useState(1)\r\n  const [result,setResult]=useState(false)\r\n  const [message,setMessage]=useState(\"\")\r\n  const [score,setScore] = useState([0])\r\n  const [ans,setAns]=useState([])\r\n  const [isOpen,setIsOpen]=useState(true)\r\n\r\n  const [checked, setChecked] = useState([]);\r\n  const { quizzDetails } = useSelector(\r\n    (state) => state.appInfo\r\n  );\r\n  if(quizzDetails === undefined) {return}\r\n  function handleAns(event){\r\n    var updatedList = [...checked];\r\n    if (event.target.checked) {\r\n    updatedList = [...checked,event.target.name];\r\n  } else {\r\n    updatedList.splice(checked.indexOf(event.target.name), 1);\r\n  }\r\n  setChecked(updatedList);\r\n  }\r\n  function isOpenn() {\r\n    setIsOpen(false)\r\n  }\r\n  if (!quizzDetails.quizz){\r\n    return null\r\n  }\r\n  const q=quizzDetails.quizz.questions[difficultyLevel]\r\n  const correctAns=quizzDetails.quizz.questions[difficultyLevel].answers\r\n  console.log(correctAns,checked)\r\n  function Right(correctAns,checked){\r\n    if (correctAns === checked) return true;\r\n    if (correctAns == null || checked == null) return false;\r\n    if (correctAns.length !== checked.length) return false;\r\n\r\n    for (var i = 0; i < correctAns.length; ++i) {\r\n      if (correctAns[i] !== checked[i]) return false;\r\n  }\r\n  return true;\r\n  }\r\n  const lastScore=score[score.length-1]\r\n  const next=async(event)=>{\r\n    event.preventDefault()\r\n    if (Right(correctAns,checked)) {\r\n      if (difficultyLevel===2) {\r\n        setResult(true)\r\n        setMessage(\"You passed the test !!!\")\r\n      }\r\n      if (difficultyLevel<=1){\r\n        setDifficultyLevel(difficultyLevel+1)\r\n      }\r\n      setScore([...score,lastScore+5])\r\n    }\r\n    else {\r\n      if (difficultyLevel===0) {\r\n        setResult(true)\r\n        setMessage(\"You failed the test !\")\r\n      }\r\n      if (difficultyLevel>=1) {\r\n        setDifficultyLevel(difficultyLevel-1)\r\n      }\r\n      setScore([...score,lastScore-2])\r\n    }\r\n    \r\n  }\r\n  \r\n  return (\r\n    <>\r\n    {isOpen && <Instructions isO={isOpenn} /> }\r\n    {!result && <div className=\"container my-4\">\r\n        <div className=\"question\">\r\n            <h4>Q. {q.question} ?</h4>\r\n            <b>Difficulty level : {difficultyLevel+1}</b>\r\n        </div>\r\n       \r\n\r\n  <div class=\"form-check\">\r\n  <input class=\"form-check-input\" type=\"checkbox\" value={q.options[0]}  id=\"A\" name=\"A\" checked={ans.A} onChange={handleAns}/>\r\n  <label class=\"form-check-label\" for=\"A\">\r\n    {q.options[0]}\r\n  </label>\r\n</div>\r\n<div class=\"form-check my-2\">\r\n  <input class=\"form-check-input\" type=\"checkbox\" value={q.options[1]} id=\"B\" name=\"B\" checked={ans.B} onChange={handleAns}/>\r\n  <label class=\"form-check-label\" for=\"B\">\r\n  {q.options[1]}\r\n  </label>\r\n</div>\r\n<div class=\"form-check my-2\">\r\n  <input class=\"form-check-input\" type=\"checkbox\" value={q.options[2]} id=\"C\" name=\"C\" checked={ans.C} onChange={handleAns}/>\r\n  <label class=\"form-check-label\" for=\"C\">\r\n  {q.options[2]}\r\n  </label>\r\n</div>\r\n<div class=\"form-check my-2\">\r\n  <input class=\"form-check-input\" type=\"checkbox\" value={q.options[3]} id=\"D\" name=\"D\" checked={ans.D} onChange={handleAns}/>\r\n  <label class=\"form-check-label\" for=\"D\">\r\n  {q.options[3]}\r\n  </label>\r\n</div>\r\n\r\n        <button class=\" btn btn-sm btn-danger\" type=\"submit\" onClick={next} >Next</button>\r\n        <h3>Score : {lastScore}</h3>\r\n    </div>}\r\n    {result && <Result mess={message} sco={score} />}\r\n    </>\r\n  )\r\n}\r\n\r\nexport default PlayQuizz\r\n","D:\\quizz-mern\\frontend\\src\\pages\\result\\Result.jsx",[],[],"D:\\quizz-mern\\frontend\\src\\actions\\userActions.js",[],[],"D:\\quizz-mern\\frontend\\src\\api\\index.js",[],[],"D:\\quizz-mern\\frontend\\src\\components\\Crousel.jsx",[],[],"D:\\quizz-mern\\frontend\\src\\components\\Album.jsx",[],[],"D:\\quizz-mern\\frontend\\src\\components\\Text.jsx",[],[],"D:\\quizz-mern\\frontend\\src\\components\\TrendingStore.jsx",[],[],"D:\\quizz-mern\\frontend\\src\\components\\Features.jsx",[],[],"D:\\quizz-mern\\frontend\\src\\components\\Pricing.jsx",[],[],"D:\\quizz-mern\\frontend\\src\\components\\About.jsx",[],[],{"ruleId":"155","severity":1,"message":"156","line":3,"column":8,"nodeType":"157","messageId":"158","endLine":3,"endColumn":12},{"ruleId":"155","severity":1,"message":"159","line":5,"column":10,"nodeType":"157","messageId":"158","endLine":5,"endColumn":21},{"ruleId":"155","severity":1,"message":"160","line":5,"column":22,"nodeType":"157","messageId":"158","endLine":5,"endColumn":33},{"ruleId":"155","severity":1,"message":"161","line":6,"column":17,"nodeType":"157","messageId":"158","endLine":6,"endColumn":26},{"ruleId":"155","severity":1,"message":"162","line":15,"column":8,"nodeType":"157","messageId":"158","endLine":15,"endColumn":13},{"ruleId":"155","severity":1,"message":"163","line":16,"column":10,"nodeType":"157","messageId":"158","endLine":16,"endColumn":14},{"ruleId":"155","severity":1,"message":"164","line":17,"column":8,"nodeType":"157","messageId":"158","endLine":17,"endColumn":21},{"ruleId":"165","severity":1,"message":"166","line":11,"column":37,"nodeType":"167","endLine":11,"endColumn":90},{"ruleId":"165","severity":1,"message":"166","line":12,"column":37,"nodeType":"167","endLine":12,"endColumn":90},{"ruleId":"165","severity":1,"message":"166","line":13,"column":37,"nodeType":"167","endLine":13,"endColumn":90},{"ruleId":"165","severity":1,"message":"166","line":14,"column":37,"nodeType